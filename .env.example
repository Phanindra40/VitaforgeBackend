PORT=8000
NODE_ENV=development
CORS_ORIGIN=*
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/?appName=<app_name>
HF_API_KEY=<your_hf_api_key>
GROQ_API_KEY=<your_groq_api_key>
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=1024
GROQ_TIMEOUT_MS=10000
TEST_UI_LOGIN_USERNAME=<your_private_login_username>
TEST_UI_LOGIN_PASSWORD=<your_private_login_password>
